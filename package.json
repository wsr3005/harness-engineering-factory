{
  "name": "harness-engineering-factory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:architecture": "tsx scripts/validate-architecture.ts",
    "validate:docs": "tsx scripts/doc-validate.ts",
    "quality:score": "tsx scripts/quality-score.ts",
    "quality:entropy": "tsx scripts/entropy-scan.ts",
    "obs:up": "tsx scripts/obs-up.ts",
    "obs:down": "tsx scripts/obs-down.ts",
    "plan:create": "tsx scripts/exec-plan-create.ts",
    "plan:list": "tsx scripts/exec-plan-list.ts",
    "plan:complete": "tsx scripts/exec-plan-complete.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.23.0",
    "husky": "^9.1.0",
    "jiti": "^2.6.1",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
